{
  "name": "@brizy/storage-server",
  "version": "1.0.0",
  "description": "Storage plugin",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "brizy": {
    "name": "Storage",
    "description": "Description of @brizy/storage plugin (server plugin).",
    "kind": "plugin",
    "displayName": "@brizy/storage-server"
  },
  "keywords": [
    "brizy",
    "storage-server"
  ],
  "author": "brizy.io",
  "license": "MIT",
  "homepage": "https://github.com/EasyBrizy/builder#readme",
  "bugs": "https://github.com/EasyBrizy/builder/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EasyBrizy/builder.git"
  },
  "scripts": {
    "lint": "eslint \"src/**/!(*.d).ts*\"",
    "prettier-check": "prettier --check \"src/**.{ts,tsx}\"",
    "dev": "nodemon --exec ts-node src/storage.ts",
    "build": "npm run clean && npx tsc",
    "start": "node dist/index.js",
    "clean": "rimraf dist",
    "clean:modules": "find . -name 'node_modules' -type d -prune -print -exec rm -rf '{}' \\;",
    "reinstall": "npm run clean:modules && npm install"
  },
  "devDependencies": {
    "@brizy/eslint-config": "*",
    "@brizy/prettier-config": "*",
    "@brizy/tsconfig": "*",
    "@types/multer": "^1.4.11",
    "nodemon": "^3.1.0"
  },
  "dependencies": {
    "@brizy/core-server": "latest",
    "dotenv": "^16.4.5",
    "express-fileupload": "^1.4.3",
    "multer": "^1.4.5-lts.1"
  },
  "files": [
    "dist",
    "package.json"
  ]
}
